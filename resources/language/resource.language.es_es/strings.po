msgid "Login (device code)"
msgstr "Acceso (código de dispositivo)"

msgctxt "#30301"
msgid "Go to [B]%s[/B] and enter this code:[CR][CR][B]%s[/B]"
msgstr "Ve a [B]%s[/B] e introduce el código:[CR][CR][B]%s[/B]"

msgctxt "#30302"
msgid "Waiting for authorization..."
msgstr "Esperando autorización..."

msgctxt "#30303"
msgid "Login successful. The access token will now be refreshed automatically."
msgstr "Acceso exitoso. El token de acceso se refrescará automáticamente."

msgctxt "#30304"
msgid "Login failed or timed out."
msgstr "Acceso fallido o fuera de tiempo."

msgctxt "#30305"
msgid "Login cancelled."
msgstr "Acceso cancelado."

msgctxt "#30306"
msgid "Device login is not available for this Client-ID.[CR]Register your own application (Public type) at dev.twitch.tv/console/apps and set its Client-ID in the add-on settings, then try again."
msgstr "El acceso de dispositivo no está disponible para este ID de Cliente.[CR]Registra tu aplicación (Tipo público) en dev.twitch.tv/console/apps, configura el ID de Cliente en los ajustes del addon y prueba de nuevo."

msgctxt "#30307"
msgid "Supported codecs"
msgstr "Codecs soportados"

msgctxt "#30308"
msgid "Twitch default"
msgstr "Por defecto de Twitch"

msgctxt "#30309"
msgid "H.265 (HEVC)"
msgstr "H.265 (HEVC)"

msgctxt "#30310"
msgid "Automatic token refresh needs a public Client-ID.[CR]Register your own application (Public type) at dev.twitch.tv/console/apps and set its Client-ID in the add-on settings."
msgstr "El refresco autommático de token necesita un ID de Cliente público.[CR]Registra tu aplicación (Tipo público) en dev.twitch.tv/console/apps, configura el ID de Cliente en los ajustes del addon."

msgctxt "#30311"
msgid "Login: ad-free playback / Turbo (device code)"
msgstr "Acceso: Sin anuncios / Turbo (código de dispositivo)"

