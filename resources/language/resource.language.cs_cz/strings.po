msgstr "Soukromé přihlašovací údaje API"

msgctxt "#30262"
msgid "Change languages"
msgstr "Změnit jazyky"

msgctxt "#30263"
msgid "Frame rate limit"
msgstr "Limit snímkové frekvence"

msgctxt "#30264"
msgid "Follow"
msgstr "Sledovat"

msgctxt "#30265"
msgid "Unfollow"
msgstr "Přestat sledovat"

msgctxt "#30266"
msgid "Add to queue"
msgstr "Přidat do fronty"

msgctxt "#30267"
msgid "An OAuth token is required for access, go to '%s' - '%s' - '%s' to generate one"
msgstr "Pro přístup je vyžadován token OAuth. Přejděte do „%s“ - „%s“ - „%s“ a vygenerujte ho"

msgctxt "#30268"
msgid "Private OAuth authentication error"
msgstr "Chyba soukromého ověření OAuth"

msgctxt "#30269"
msgid "Private OAuth credentials are incorrect, go to '%s' - '%s' - '%s' to correct the issue"
msgstr "Soukromé přihlašovací údaje OAuth nejsou správné. Přejděte do „%s“ - „%s“ - „%s“ a opravte problém"

msgctxt "#30270"
msgid "Subscriber and Turbo Benefits"
msgstr "Výhody pro předplatitele a Turbo"

msgctxt "#30271"
msgid "For information on how to obtain this token, visit"
msgstr "Informace o získání tohoto tokenu najdete na"

msgctxt "#30272"
msgid "https://twitchaddon.page.link/benefits"
msgstr "https://twitchaddon.page.link/benefits"

msgctxt "#30273"
msgid "OAuth Token is expired or invalid"
msgstr "Token OAuth vypršel nebo je neplatný"

msgctxt "#30300"
msgid "Login (device code)"
msgstr "Přihlášení pomocí kódu zařízení"

msgctxt "#30301"
msgid "Go to [B]%s[/B] and enter this code:[CR][CR][B]%s[/B]"
msgstr "Přejděte na [B]%s[/B] a zadejte tento kód:[CR][CR][B]%s[/B]"

msgctxt "#30302"
msgid "Waiting for authorization..."
msgstr "Čekání na autorizaci..."

msgctxt "#30303"
msgid "Login successful. The access token will now be refreshed automatically."
msgstr "Přihlášení bylo úspěšné. Přístupový token se nyní bude obnovovat automaticky."

msgctxt "#30304"
msgid "Login failed or timed out."
msgstr "Přihlášení se nezdařilo nebo vypršel časový limit."

msgctxt "#30305"
msgid "Login cancelled."
msgstr "Přihlášení bylo zrušeno."

msgctxt "#30306"
msgid "Device login is not available for this Client-ID.[CR]Register your own application (Public type) at dev.twitch.tv/console/apps and set its Client-ID in the add-on settings, then try again."
msgstr "Přihlášení pomocí kódu zařízení není pro toto ID klienta dostupné.[CR]Zaregistrujte vlastní aplikaci (typ Public) na dev.twitch.tv/console/apps, nastavte její ID klienta v nastavení doplňku a zkuste to znovu."

msgctxt "#30307"
msgid "Supported codecs"
msgstr "Podporované kodeky"

msgctxt "#30308"
msgid "Twitch default"
msgstr "Výchozí nastavení služby Twitch"

msgctxt "#30309"
msgid "H.265 (HEVC)"
msgstr "H.265 (HEVC)"

msgctxt "#30310"
msgid "Automatic token refresh needs a public Client-ID.[CR]Register your own application (Public type) at dev.twitch.tv/console/apps and set its Client-ID in the add-on settings."
msgstr "Automatická obnova tokenu vyžaduje ID klienta veřejné aplikace.[CR]Zaregistrujte vlastní aplikaci (typ Public) na dev.twitch.tv/console/apps a nastavte její ID klienta v nastavení doplňku."

msgctxt "#30311"
msgid "Login: ad-free playback / Turbo (device code)"
msgstr "Přihlášení pro přehrávání bez reklam / Turbo (kód zařízení)"

msgctxt "#30312"
msgid "Go to [B]%s[/B] with your [B]Turbo/subscriber account[/B] and enter this code:[CR][CR][B]%s[/B]"
msgstr "Přihlaste se na [B]%s[/B] pomocí svého [B]účtu s Turbo nebo předplatným[/B] a zadejte tento kód:[CR][CR][B]%s[/B]"

msgctxt "#30313"
msgid "Turbo / ad-free login successful. The token is renewed automatically. Ad-free playback only applies if the logged-in account has Turbo or is subscribed to the channel."
msgstr "Přihlášení pro Turbo / přehrávání bez reklam bylo úspěšné. Token se obnovuje automaticky. Přehrávání bez reklam platí pouze v případě, že má přihlášený účet Turbo nebo předplatné daného kanálu."

msgctxt "#30330"
msgid "Search method"
msgstr "Způsob hledání"

msgctxt "#30331"
msgid "Website (twitch.tv, fuzzy)"
msgstr "Web (twitch.tv, přibližná shoda)"

msgctxt "#30332"
msgid "Helix API"
msgstr "API Helix"

