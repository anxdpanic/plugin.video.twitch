                    <level>0</level>
                    <control type="button" format="action"/>
                    <data>RunPlugin(plugin://$ID/?mode=maintain&amp;sub_mode=delete&amp;file_type=channels_search)</data>
                </setting>
                <setting id="delete_games_search" type="action" label="30247" help="">
                    <level>0</level>
                    <control type="button" format="action"/>
                    <data>RunPlugin(plugin://$ID/?mode=maintain&amp;sub_mode=delete&amp;file_type=games_search)</data>
                </setting>
                <setting id="delete_idurl_search" type="action" label="30248" help="">
                    <level>0</level>
                    <control type="button" format="action"/>
                    <data>RunPlugin(plugin://$ID/?mode=maintain&amp;sub_mode=delete&amp;file_type=id_url_search)</data>
                </setting>
            </group>
            <group id="2" label="30249">
                <setting id="delete_storage_json" type="action" label="30250" help="">
                    <level>1</level>
                    <control type="button" format="action"/>
                    <data>RunPlugin(plugin://$ID/?mode=maintain&amp;sub_mode=delete&amp;file_type=storage_json)</data>
