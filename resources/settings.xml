<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings version="1">
    <section id="plugin.video.twitch">
        <!-- ==================== Login ==================== -->
        <category id="login" label="30127" help="">
            <group id="0" label="30310">
                <setting id="is_device_authenticated" type="boolean" label="" help="">
                    <level>0</level>
                    <default>false</default>
                    <visible>false</visible>
                    <control type="toggle"/>
                </setting>
                <setting id="device_auth_connect" type="action" label="30314" help="">
                    <level>0</level>
                    <control type="button" format="action"/>
                    <data>RunPlugin(plugin://$ID/?mode=device_auth)</data>
                    <dependencies>
                        <dependency type="visible" setting="is_device_authenticated">false</dependency>
                    </dependencies>
                </setting>
                <setting id="device_auth_disconnect" type="action" label="30315" help="">
                    <level>0</level>
                    <control type="button" format="action"/>
                    <data>RunPlugin(plugin://$ID/?mode=device_auth_disconnect)</data>
                    <dependencies>
                        <dependency type="visible" setting="is_device_authenticated">true</dependency>
                    </dependencies>
                </setting>
                <setting id="revoke_token" type="action" label="30227" help="">
                    <level>0</level>
                    <control type="button" format="action"/>
                    <data>RunPlugin(plugin://$ID/?mode=revoke_token)</data>
                    <dependencies>
                        <dependency type="visible" setting="is_device_authenticated">true</dependency>
                    </dependencies>
                </setting>
            </group>
            <group id="1" label="30280">
                <setting id="twitch_client_id" type="string" label="30281" help="30321">
                    <level>0</level>
                    <default/>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string"/>
                </setting>
                <setting id="twitch_client_secret" type="string" label="30330" help="30331">
                    <level>0</level>
                    <default/>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string" hidden="true"/>
                </setting>
            </group>
            <group id="2" label="30282">
                <setting id="twitch_hevc_token" type="string" label="30279" help="">
                    <level>0</level>
                    <default/>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string"/>
                </setting>
            </group>
            <!-- Hidden settings managed internally via setSetting/getSetting.
                 Must be defined here for Kodi 21+ (Omega) to persist them properly. -->
            <group id="3" label="">
                <setting id="oauth_token_helix" type="string" label="" help="">
                    <level>0</level>
                    <default/>
                    <visible>false</visible>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string"/>
                </setting>
                <setting id="device_refresh_token" type="string" label="" help="">
                    <level>0</level>
                    <default/>
                    <visible>false</visible>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string"/>
                </setting>
                <setting id="device_token_expires_at" type="string" label="" help="">
                    <level>0</level>
                    <default/>
                    <visible>false</visible>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string"/>
                </setting>
            </group>
        </category>

