        <!-- ==================== Developer ==================== -->
        <category id="developer" label="30118" help="">
            <group id="1" label="OAuth">
                <setting id="oauth_clientid" type="string" label="30097" help="">
                    <level>3</level>
                    <default/>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string"/>
                </setting>
                <setting id="oauth_redirecturi" type="string" label="30142" help="">
                    <level>3</level>
                    <default/>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string"/>
                </setting>
            </group>
        </category>
    </section>
</settings>
