                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="menu_search_channels" type="boolean" label="30008" help="">
                    <level>1</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="menu_search_games" type="boolean" label="30001" help="">
                    <level>1</level>
